# Ignore build and binary files
*.exe
*.out
*.obj
*.o
*.dll
*.lib
*.so
*.a
*.tlog

# Ignore Visual Studio files
.vscode/
.vs/
*.vcxproj*
*.sln
*.suo
*.user
*.ncb
*.pdb
*.idb
