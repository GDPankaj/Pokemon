# Ignore temporary files
*.log
*.tmp
*.swp
*.bak

# Ignore Clang/GCC compilation files
*.d
*.gcda
*.gcno
*.gcov

# Ignore compiled game assets (optional)
assets/*.png
assets/*.wav
assets/*.ogg
